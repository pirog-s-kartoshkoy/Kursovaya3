<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="374.0" prefWidth="329.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kursovaya3.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <Label prefHeight="37.0" prefWidth="250.0" text="Привет! Войди или зарегестрируйся" textAlignment="CENTER" />

    <Label fx:id="welcomeText" />
   <HBox prefHeight="35.0" prefWidth="289.0">
      <children>
         <TextField fx:id="loginField" prefHeight="26.0" prefWidth="336.0" promptText="Введи логин" />
      </children>
   </HBox>
   <HBox prefHeight="38.0" prefWidth="289.0">
      <children>
         <PasswordField fx:id="passwordField" prefHeight="26.0" prefWidth="292.0" promptText="Введи пароль" />
      </children>
   </HBox>
   <HBox prefHeight="29.0" prefWidth="289.0" spacing="150.0">
      <children>
         <Button alignment="CENTER" contentDisplay="BOTTOM" mnemonicParsing="false" onAction="#onLoginButtonClick" prefHeight="29.0" prefWidth="71.0" text="Вход" />
         <Button mnemonicParsing="false" prefHeight="30.0" prefWidth="113.0" text="Регистрация" />
      </children>
   </HBox>
</VBox>
