<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kursovaya3.AddCarController">
    <children>
        <Label text="Добавление автомобиля">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <ComboBox fx:id="modelComboBox" promptText="Выберите модель автомобиля" prefWidth="250.0" />

        <TextField fx:id="numberField" promptText="Гос. номер машины" prefWidth="250.0" />

        <Button mnemonicParsing="false" onAction="#onSaveClick" prefWidth="150.0" text="Сохранить" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>