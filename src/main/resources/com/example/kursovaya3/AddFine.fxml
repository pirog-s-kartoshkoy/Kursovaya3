<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kursovaya3.AddFineController">
    <children>
        <Label text="Начисление штрафа по заказу">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <Label fx:id="tripInfoLabel" text="Заказ №..." wrapText="true" alignment="CENTER"/>

        <ComboBox fx:id="fineTypeComboBox" promptText="Выберите тип нарушения" prefWidth="300.0" />

        <Button mnemonicParsing="false" onAction="#onSaveFineClick" prefWidth="120.0" text="Выписать" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>