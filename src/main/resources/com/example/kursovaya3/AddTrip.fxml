<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kursovaya3.AddTripController">
    <children>
        <Label text="Оформление проката">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <ComboBox fx:id="clientComboBox" promptText="Выберите клиента" prefWidth="300.0" />

        <ComboBox fx:id="carComboBox" promptText="Выберите автомобиль" prefWidth="300.0" />

        <TextField fx:id="durationField" promptText="Количество дней проката" prefWidth="300.0" />

        <Button mnemonicParsing="false" onAction="#onSaveClick" prefWidth="150.0" text="Оформить" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>